import pandas as pd

data = {
'Region':['East','West','East','North','West'],
'Manager':['A','B','A','C','B'],
'Salesman':['John','Sam','Mary','Tom','John'],
'Sales':[5000,7000,6000,5500,6500]
}

df = pd.DataFrame(data)

pivot = pd.pivot_table(df, values='Sales',
                       index=['Region','Manager','Salesman'],
                       aggfunc='sum')

print(pivot)
